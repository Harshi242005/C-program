#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* kth_word_in_mth_sentence_of_nth_paragraph(char**** document, int k, int m, int n) {
    // Note: n=paragraph, m=sentence, k=word. 1-indexed.
    return document[n-1][m-1][k-1];
}

char** kth_sentence_in_mth_paragraph(char**** document, int k, int m) {
    // Note: m=paragraph, k=sentence. 1-indexed.
    return document[m-1][k-1];
}

char*** kth_paragraph(char**** document, int k) {
    // Note: k=paragraph. 1-indexed.
    return document[k-1];
}

char**** get_document(char* text) {
    char**** doc = NULL;
    int p_idx = 0, s_idx = 0, w_idx = 0;

    // Start with 1 paragraph
    doc = malloc(sizeof(char***));
    doc[p_idx] = malloc(sizeof(char**));
    doc[p_idx][s_idx] = malloc(sizeof(char*));

    char* word = malloc(sizeof(char) * 1024); // Buffer for word
    int char_idx = 0;

    for (int i = 0; i <= strlen(text); i++) {
        if (text[i] == ' ' || text[i] == '.' || text[i] == '\n' || text[i] == '\0') {
            // Finish current word
            word[char_idx] = '\0';
            doc[p_idx][s_idx][w_idx] = malloc(sizeof(char) * (char_idx + 1));
            strcpy(doc[p_idx][s_idx][w_idx], word);
            char_idx = 0;
            w_idx++;

            if (text[i] == '.') {
                s_idx++;
                w_idx = 0;
                doc[p_idx] = realloc(doc[p_idx], sizeof(char**) * (s_idx + 1));
                doc[p_idx][s_idx] = malloc(sizeof(char*));
            } else if (text[i] == '\n') {
                p_idx++;
                s_idx = 0;
                w_idx = 0;
                doc = realloc(doc, sizeof(char***) * (p_idx + 1));
                doc[p_idx] = malloc(sizeof(char**));
                doc[p_idx][s_idx] = malloc(sizeof(char*));
            } else if (text[i] == ' ') {
                doc[p_idx][s_idx] = realloc(doc[p_idx][s_idx], sizeof(char*) * (w_idx + 1));
            }
        } else {
            word[char_idx++] = text[i];
        }
    }
    free(word);
    return doc;
}
