#include <stdarg.h>
#include <stdio.h>
#include <limits.h>

int sum (int count,...) {
    va_list args;
    va_start(args, count);
    int total = 0;

    for (int i = 0; i < count; i++) {
        total += va_arg(args, int);
    }

    va_end(args);
    return total;
}

int min(int count,...) {
    va_list args;
    va_start(args, count);
    
    // Initialize min with the first argument or a very large number
    int minimum = va_arg(args, int);

    for (int i = 1; i < count; i++) {
        int current = va_arg(args, int);
        if (current < minimum) {
            minimum = current;
        }
    }

    va_end(args);
    return minimum;
}

int max(int count,...) {
    va_list args;
    va_start(args, count);
    
    // Initialize max with the first argument
    int maximum = va_arg(args, int);

    for (int i = 1; i < count; i++) {
        int current = va_arg(args, int);
        if (current > maximum) {
            maximum = current;
        }
    }

    va_end(args);
    return maximum;
}
