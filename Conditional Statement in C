#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    // Array to store English representations for indices 1-9
    // Index 0 is a placeholder since the task specifies positive integers starting at 1
    char *numbers[] = {"", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine"};

    if (n >= 1 && n <= 9) {
        // Access the word directly from the array using n as the index
        printf("%s\n", numbers[n]);
    } else {
        // Handle numbers greater than 9
        printf("Greater than 9\n");
    }

    return 0;
}
