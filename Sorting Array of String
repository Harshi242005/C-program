#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// 1. Rename to match HackerRank call: lexicographic_sort
int lexicographic_sort(const char* a, const char* b) {
    return strcmp(a, b);
}

// 2. Rename to match HackerRank call: lexicographic_sort_reverse
int lexicographic_sort_reverse(const char* a, const char* b) {
    return strcmp(b, a);
}

// Helper to count distinct characters
int count_distinct(const char* s) {
    int count = 0;
    int hash[26] = {0};
    for (int i = 0; s[i] != '\0'; i++) {
        if (hash[s[i] - 'a'] == 0) {
            hash[s[i] - 'a'] = 1;
            count++;
        }
    }
    return count;
}

// 3. Keep name: sort_by_number_of_distinct_characters
int sort_by_number_of_distinct_characters(const char* a, const char* b) {
    int res = count_distinct(a) - count_distinct(b);
    if (res == 0) return strcmp(a, b);
    return res;
}

// 4. Keep name: sort_by_length
int sort_by_length(const char* a, const char* b) {
    int res = strlen(a) - strlen(b);
    if (res == 0) return strcmp(a, b);
    return res;
}

// Final Function: string_sort
void string_sort(char** arr, const int len, int (*cmp_func)(const char* a, const char* b)) {
    for (int i = 0; i < len; i++) {
        for (int j = 0; j < len - 1; j++) {
            if (cmp_func(arr[j], arr[j + 1]) > 0) {
                char* temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}
