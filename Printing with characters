#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>


int main() {
    char ch;
    char s[100];
    char sen[100];

    // Read the character
    scanf("%c", &ch);
    
    // Read the single word string
    scanf("%s", s);
    
    // Crucial: Use "\n" to consume the newline character left in the buffer
    // before reading the sentence.
    scanf("\n");
    
    // Read the full sentence until the newline
    scanf("%[^\n]%*c", sen);

    // Output the results
    printf("%c\n", ch);
    printf("%s\n", s);
    printf("%s\n", sen);

    return 0;
}
