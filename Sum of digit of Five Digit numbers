#include <stdio.h>

int main() {
    int n, sum = 0;
    
    // Read the five-digit integer
    scanf("%d", &n);
    
    // Process each digit
    while (n > 0) {
        sum += (n % 10); // Extract the last digit and add to sum
        n /= 10;         // Remove the last digit
    }
    
    // Print the final sum
    printf("%d\n", sum);
    
    return 0;
}
