#include <stdio.h>
#include <stdlib.h>
#include <math.h>

struct triangle {
	int a;
	int b;
	int c;
};

typedef struct triangle triangle;

// Function to calculate the square of the area to avoid unnecessary sqrt() calls
double get_area(triangle tr) {
    double p = (tr.a + tr.b + tr.c) / 2.0;
    // Heron's Formula: Area = sqrt(p * (p-a) * (p-b) * (p-c))
    // We can compare area^2 to avoid floating point precision issues with sqrt
    return p * (p - tr.a) * (p - tr.b) * (p - tr.c);
}

void sort_by_area(triangle* tr, int n) {
    // Basic Bubble Sort to sort the structures based on calculated area
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (get_area(tr[j]) > get_area(tr[j + 1])) {
                // Swap the entire structure
                triangle temp = tr[j];
                tr[j] = tr[j + 1];
                tr[j + 1] = temp;
            }
        }
    }
}

int main() {
	int n;
	scanf("%d", &n);
	triangle *tr = malloc(n * sizeof(triangle));
	for (int i = 0; i < n; i++) {
		scanf("%d %d %d", &tr[i].a, &tr[i].b, &tr[i].c);
	}
	sort_by_area(tr, n);
	for (int i = 0; i < n; i++) {
		printf("%d %d %d\n", tr[i].a, tr[i].b, tr[i].c);
	}
	free(tr);
	return 0;
}
